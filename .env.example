# Sao chép file này thành .env rồi điền giá trị thật.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# URL public ngrok in ra từ notebook Kaggle (Cell 5). Đổi mỗi phiên Kaggle.
# Ví dụ: https://xxxx-xx-xx-xx.ngrok-free.app   (KHÔNG có dấu / ở cuối)
REMOTE_API_URL=

# Token bí mật — phải KHỚP với VIHATET5_API_TOKEN đặt ở Cell 3 trên Kaggle.
REMOTE_API_TOKEN=vihs-2026-x7k9qm

# (tuỳ chọn) timeout cho mỗi request, giây. Trace đầy đủ có thể mất vài giây.
REMOTE_API_TIMEOUT=60

# Ép dùng MOCK MODEL (dữ liệu giả, không gọi Kaggle). Tiện để show trước khi host.
#   - bỏ trống / "0" : tự chọn (có URL -> dùng thật; trống -> mock)
#   - "1" / "true"   : luôn dùng mock, kể cả khi đã có REMOTE_API_URL
MOCK_MODE=
